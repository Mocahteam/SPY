	</script>

	<script outputLine="Plok_Sol" editMode="2" type="4">
		<while>
			<condition>
				<not>
					<captor type="Exit"/>
				</not>
			</condition>
			<container>
				<action type="Forward"/>
				<if>
					<condition>
						<captor type="PathLeft"/>
					</condition>
					<container>
						<action type="TurnLeft"/>
					</container>
				</if>
				<if>
					<condition>
						<captor type="PathRight"/>
					</condition>
					<container>
						<action type="TurnRight"/>
					</container>
				</if>
			</container>
		</while>
	</script>


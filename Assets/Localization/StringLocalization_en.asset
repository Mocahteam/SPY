      m_Items: []
  - m_Id: 326166952563433472
    m_Localized: 'Optimal: the given script is the optimal solution for the mission<br>Non
      Optimal: the given script resolve the mission but it can be optimized<br>Bugged:
      the given script doesn''t resolve the mission (bug or incomplete)<br>Undefined
      (default)<br>Hidden: the given script is a solution (hidden to the player)'
    m_Metadata:
      m_Items: []

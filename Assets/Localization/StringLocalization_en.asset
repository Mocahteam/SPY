    m_Localized: 'Locked: the player can''t rename the script<br>Synchronized:  if
      the player renames the script it will automatically renames associated player
      tags<br>Editable (default): if the player renames the script it will not automatically
      renames associated player tags'
    m_Metadata:
      m_Items: []
  - m_Id: 326151485178241024
